{
  "expo": {
    "name": "mynox",
    "slug": "mynox",
    "scheme": "mynox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07080f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mynox",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07080f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#a855f7",
          "defaultChannel": "mynox-default",
          "androidMode": "default",
          "androidCollapsedTitle": "MyNox"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.mynox.app",
          "enableGooglePay": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22880ea8-b6d4-48f2-a496-3fffcba2c0cf"
      }
    },
    "owner": "mynoxsupports-organization"
  }
}
